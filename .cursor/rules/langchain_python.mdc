## 6. Error Handling and Logging

### LangChain Specific Error Handling
```python
from typing import Optional
import logging

class LangChainError(Exception):
    """Base exception for LangChain operations."""
    pass

class VectorStoreError(LangChainError):
    """Raised when vector store operations fail."""
    pass

class AgentExecutionError(LangChainError):
    """Raised when agent execution fails."""
    pass

class TwitterDataProcessingError(LangChainError):
    """Raised when Twitter data processing fails."""
    pass

class TwitterDataFlowLogger:
    """Structured logger for Twitter data flow operations."""

    def __init__(self, name: str = "twitter_data_flow"):
        self.logger = logging.getLogger(name)

    def log_data_processing_start(self, topic: str, tweet_count: int):
        """Log the start of data processing."""
        self.logger.info("Starting Twitter data processing", extra={
            'event': 'data_processing_start',
            'topic': topic,
            'tweet_count': tweet_count
        })

    def log_vector_store_operation(self, operation: str, document_count: int):
        """Log vector store operations."""
        self.logger.info("Vector store operation", extra={
            'event': 'vector_store_operation',
            'operation': operation,
            'document_count': document_count
        })

    def log_agent_execution(self, agent_type: str, query: str, success: bool):
        """Log agent execution."""
        level = logging.INFO if success else logging.ERROR
        self.logger.log(level, "Agent execution", extra={
            'event': 'agent_execution',
            'agent_type': agent_type,
            'query': query,
            'success': success
        })

    def log_error(self, error_type: str, error_message: str, context: Optional[Dict] = None):
        """Log errors with context."""
        self.logger.error("Operation failed", extra={
            'event': 'error',
            'error_type': error_type,
            'error_message': error_message,
            'context': context or {}
        })
```

## 7. Configuration Management

### LangChain Configuration
```python
from pydantic import BaseSettings
from typing import Optional, List

class LangChainConfig(BaseSettings):
    """Configuration for LangChain components."""

    # Vector Store Configuration
    vector_db_path: str = "./twitter_vector_db"
    embedding_model: str = "mxbai-embed-large"
    chunk_size: int = 1000
    chunk_overlap: int = 200

    # Agent Configuration
    agent_temperature: float = 0.1
    agent_max_tokens: int = 2000
    agent_max_iterations: int = 10

    # Twitter Data Configuration
    max_tweets_per_topic: int = 100
    tweet_lookback_hours: int = 24

    # Performance Configuration
    batch_size: int = 50
    parallel_processing: bool = True

    class Config:
        env_prefix = "LANGCHAIN_"
        case_sensitive = False

def get_langchain_config() -> LangChainConfig:
    """Get LangChain configuration."""
    return LangChainConfig()
```

## 8. Testing Patterns

### Unit Testing for LangChain Components
```python
import pytest
from unittest.mock import Mock, patch
from langchain_core.documents import Document

class TestTwitterDataProcessor:
    """Test cases for Twitter data processor."""

    @pytest.fixture
    def processor(self):
        return TwitterDataProcessor(chunk_size=500, chunk_overlap=100)

    @pytest.fixture
    def sample_tweets(self):
        return [
            TwitterData(
                tweet_id="123",
                content="Test tweet content",
                author="testuser",
                timestamp=datetime.now(),
                hashtags=["test", "example"],
                mentions=["@user1"],
                engagement_metrics={"likes": 10, "retweets": 5}
            )
        ]

    def test_process_twitter_data(self, processor, sample_tweets):
        """Test processing Twitter data into documents."""
        documents = processor.process_twitter_data(sample_tweets)

        assert len(documents) > 0
        assert all(isinstance(doc, Document) for doc in documents)
        assert all("tweet_id" in doc.metadata for doc in documents)

    def test_format_tweet_content(self, processor, sample_tweets):
        """Test tweet content formatting."""
        tweet = sample_tweets[0]
        content = processor._format_tweet_content(tweet)

        assert "Test tweet content" in content
        assert "testuser" in content
        assert "test, example" in content

class TestTwitterVectorStore:
    """Test cases for Twitter vector store."""

    @pytest.fixture
    def vector_store(self, tmp_path):
        return TwitterVectorStore(db_path=str(tmp_path))

    def test_initialize_store(self, vector_store):
        """Test vector store initialization."""
        assert vector_store.vector_store is not None
        assert vector_store.embeddings is not None

    def test_add_documents(self, vector_store):
        """Test adding documents to vector store."""
        documents = [
            Document(page_content="Test content", metadata={"test": "data"})
        ]

        doc_ids = vector_store.add_twitter_documents(documents)
        assert len(doc_ids) == 1

    def test_similarity_search(self, vector_store):
        """Test similarity search functionality."""
        # Add test documents first
        documents = [
            Document(page_content="Twitter data analysis", metadata={"topic": "analysis"}),
            Document(page_content="Machine learning insights", metadata={"topic": "ml"})
        ]
        vector_store.add_twitter_documents(documents)

        # Search for similar content
        results = vector_store.similarity_search("data analysis", k=1)
        assert len(results) > 0
