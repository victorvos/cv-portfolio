## 🚨 Error Handling

### Custom Exception Hierarchy
```python
# core/exceptions.py
class ArticleServiceError(Exception):
    """Base exception for article service errors."""
    pass

class ArticleNotFoundError(ArticleServiceError):
    """Raised when article is not found."""
    pass

class ValidationError(ArticleServiceError):
    """Raised when article data validation fails."""
    pass

class DatabaseError(ArticleServiceError):
    """Raised when database operation fails."""
    pass
```

### Error Handling in Routes
```python
# presentation/api/routes.py
from fastapi import APIRouter, HTTPException, Depends
from core.services.article_service import ArticleService
from core.exceptions import ArticleNotFoundError

router = APIRouter()

@router.get("/articles/{article_id}")
async def get_article(
    article_id: str,
    service: ArticleService = Depends()
):
    """Get an article by ID."""
    try:
        article = await service.get_article(article_id)
        return article
    except ArticleNotFoundError:
        raise HTTPException(status_code=404, detail="Article not found")
    except Exception as e:
        raise HTTPException(status_code=500, detail="Internal server error")
```

## 🔧 Dependency Injection

### Container Configuration
```python
# core/container.py
from dependency_injector import containers, providers
from core.services.article_service import ArticleService
from infrastructure.repositories.firebase_article_repository import FirebaseArticleRepository

class Container(containers.DeclarativeContainer):
    """Dependency injection container."""

    # Configuration
    config = providers.Configuration()

    # Repositories
    article_repository = providers.Factory(
        FirebaseArticleRepository,
        config=config.firebase
    )

    # Services
    article_service = providers.Factory(
        ArticleService,
        repository=article_repository
    )
```

### Repository Pattern
```python
# core/interfaces/article_repository.py
from abc import ABC, abstractmethod
from typing import List, Optional
from core.entities.article import Article

class ArticleRepository(ABC):
    """Abstract repository for article data access."""

    @abstractmethod
    async def find_all(self, filters: dict = None) -> List[Article]:
        """Find all articles with optional filters."""
        pass

    @abstractmethod
    async def find_by_id(self, article_id: str) -> Optional[Article]:
        """Find article by ID."""
        pass

    @abstractmethod
    async def save(self, article: Article) -> Article:
        """Save article to database."""
        pass
```

## 📝 Logging and Monitoring

### Structured Logging
```python
# utils/logging_utils.py
import logging
import json
from typing import Any, Dict

class StructuredLogger:
    """Structured logger for application events."""

    def __init__(self, name: str, level: str = "INFO"):
        self.logger = logging.getLogger(name)
        self.logger.setLevel(getattr(logging, level.upper()))

    def log_article_operation(self, operation: str, article_id: str, **kwargs):
        """Log article operations with structured data."""
        self.logger.info("Article operation", extra={
            'event': 'article_operation',
            'operation': operation,
            'article_id': article_id,
            **kwargs
        })

    def log_api_request(self, method: str, path: str, status_code: int, **kwargs):
        """Log API requests with structured data."""
        self.logger.info("API request", extra={
            'event': 'api_request',
            'method': method,
            'path': path,
            'status_code': status_code,
            **kwargs
        })
```

### Configuration Management
```python
# core/config.py
from pydantic import BaseSettings
from typing import List

class Settings(BaseSettings):
    """Application settings with environment variable support."""

    # Application
    app_name: str = "Darom"
    app_version: str = "1.0.0"
    debug: bool = False

    # Database
    firebase_project_id: str
    firebase_credentials_path: str

    # External Services
    openai_api_key: str
    xai_api_key: str
    twitter_api_key: str

    # CORS
    cors_origins: List[str] = ["http://localhost:3000"]

    class Config:
        env_file = ".env"
        case_sensitive = False

def get_settings() -> Settings:
    """Get application settings."""
    return Settings()
```

## 🧪 Testing Patterns

### Unit Testing
```python
# tests/unit/core/test_article_service.py
import pytest
from unittest.mock import Mock, AsyncMock
from core.services.article_service import ArticleService
from core.entities.article import Article
from core.exceptions import ArticleNotFoundError

class TestArticleService:
    """Test cases for ArticleService."""

    @pytest.fixture
    def mock_repository(self):
        return Mock()

    @pytest.fixture
    def service(self, mock_repository):
        return ArticleService(mock_repository)

    @pytest.mark.asyncio
    async def test_get_article_success(self, service, mock_repository):
        """Test successful article retrieval."""
        # Arrange
        article_id = "test-id"
        expected_article = Article(
            id=article_id,
            title="Test Article",
            content="Test content",
            author="Test Author"
        )
        mock_repository.find_by_id.return_value = expected_article

        # Act
        result = await service.get_article(article_id)

        # Assert
        assert result == expected_article
        mock_repository.find_by_id.assert_called_once_with(article_id)

    @pytest.mark.asyncio
    async def test_get_article_not_found(self, service, mock_repository):
        """Test article not found scenario."""
        # Arrange
        article_id = "non-existent"
        mock_repository.find_by_id.return_value = None

        # Act & Assert
        with pytest.raises(ArticleNotFoundError):
            await service.get_article(article_id)
```

